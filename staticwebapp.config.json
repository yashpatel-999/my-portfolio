{
    "routes": [
        {
            "route": "/*",
            "serve": "/index.html",
            "statusCode": 200
        }
    ],
    "mimeTypes": {
        ".json": "application/json",
        ".wasm": "application/wasm"
    },
    "auth": {
        "rolesSource": "/roles.json"
    },
    "globalHeaders": {
        "content-security-policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self'; object-src 'none';"
    },
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/images/*",
            "/css/*",
            "/js/*",
            "*.svg",
            "*.png",
            "*.jpg",
            "*.gif",
            "*.ico"
        ]
    }
}